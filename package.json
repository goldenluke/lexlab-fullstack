{
  "name": "realtime",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --prefix apps/web -- --host",
    "dev:realtime": "node apps/realtime/server.mjs",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:realtime\"",
    "build:web": "npm run build --prefix apps/web",
    "start:web": "cd apps/web && node server.mjs"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1"
  }
}
