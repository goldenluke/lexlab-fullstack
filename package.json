{
  "name": "realtime",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:realtime": "cd apps/realtime && node server.mjs",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:realtime\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "overrides": {
    "yjs": "13.6.9"
  },
  "dependencies": {
    "diff": "^8.0.3"
  }
}
