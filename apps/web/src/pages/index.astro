---
import { useState } from 'react';
import MinutaLive from '../components/MinutaLive.astro'; // Certifique-se de que o caminho está correto

const [isLive, setIsLive] = useState(false);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Minuta Live</title>
  </head>
  <body>
    <header>
      <h1>Minuta Legal - Dashboard</h1>
    </header>
    <main>
      <!-- Teste de integração do componente MinutaLive -->
      <div>
        <button onClick={() => setIsLive(!isLive)}>
          {isLive ? 'Desligar MinutaLive' : 'Ligar MinutaLive'}
        </button>

        <!-- Condicional para exibir o componente MinutaLive -->
        {isLive && <MinutaLive />}
      </div>

      <!-- Outros conteúdos ou componentes que você queira adicionar -->
      <section>
        <h2>Informações de Saúde</h2>
        <p>Aqui você pode adicionar detalhes sobre saúde pública, jurisprudência ou outros dados.</p>
      </section>
    </main>
  </body>
</html>
